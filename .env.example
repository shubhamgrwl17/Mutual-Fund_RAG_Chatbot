# -----------------------------
# Phase 3.2: Chroma Indexing
# -----------------------------

# Path to embedded corpus produced by Phase 3.1
EMBEDDED_CHUNKS_PATH=data/embeddings/corpus_with_embeddings.jsonl

# local | remote
CHROMA_MODE=local

# Chroma collection name
CHROMA_COLLECTION=mutual_fund_faq

# Local mode (PersistentClient)
CHROMA_PERSIST_DIR=data/vector_db

# Remote mode (HttpClient) - Hugging Face Space URL host/port
# Example host for space URL:
# https://<username>-<space-name>.hf.space  -> host: <username>-<space-name>.hf.space
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false

# Optional token for private remote endpoints (Bearer token)
# For Hugging Face private spaces, use your HF access token.
CHROMA_AUTH_TOKEN=

# Batch size used by collection.upsert()
CHROMA_BATCH_SIZE=100
